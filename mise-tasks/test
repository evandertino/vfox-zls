#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force zls .
mise cache clear
mise install zls@0.16.0

# Capture and display the output while also verifying it
output=$(mise exec "zls@0.16.0" -- "zls" --version)
echo "zls output: $output"

if echo "$output" | grep -q '0.16.0'; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected version 0.16.0"
    exit 1
fi
